DATABASE_URL=

# NextAuth v5 — generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=

# GitHub OAuth — create at https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Resend — for transactional email (verification, etc.)
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender address. Defaults to onboarding@resend.dev for dev.
# In production, use a verified domain like noreply@yourdomain.com.
EMAIL_FROM=

# Public URL of the app — used for verification links in emails.
# Defaults to http://localhost:3000 for dev.
APP_URL=

# Toggle email verification on register. Defaults to "true".
# Set to "false" if you don't have a verified Resend domain yet —
# new users will be auto-verified and credentials sign-in works immediately.
# Accepts: true|1|yes  /  false|0|no
EMAIL_VERIFICATION_ENABLED=

# Upstash Redis — rate limiting for auth endpoints.
# Create a database at https://console.upstash.com/redis (free tier is plenty
# for auth limiting). Leave both blank to disable rate limiting (fail-open).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe — test mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# Webhook signing secret. For local dev, run:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# and paste the printed `whsec_…` here. For hosted environments, copy it from
# the Webhook endpoint you create in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=""

# Recurring price IDs for the "DevStash Pro" product
# (Dashboard → Products → DevStash Pro → copy each `price_…` id).
STRIPE_PRICE_ID_MONTHLY=""
STRIPE_PRICE_ID_YEARLY=""

# Cloudflare R2 — object storage for file/image uploads.
# Create a bucket in https://dash.cloudflare.com/ → R2 and an
# R2 API token (Account → R2 → Manage API Tokens).
# R2_ACCOUNT_ID is the Cloudflare account ID (Dashboard → top-right).
# R2_PUBLIC_URL is the bucket's public r2.dev URL (Bucket → Settings → Public access).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
