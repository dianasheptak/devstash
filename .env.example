DATABASE_URL=

# NextAuth v5 — generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=

# GitHub OAuth — create at https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Resend — for transactional email (verification, etc.)
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender address. Defaults to onboarding@resend.dev for dev.
# In production, use a verified domain like noreply@yourdomain.com.
EMAIL_FROM=

# Public URL of the app — used for verification links in emails.
# Defaults to http://localhost:3000 for dev.
APP_URL=

# Toggle email verification on register. Defaults to "true".
# Set to "false" if you don't have a verified Resend domain yet —
# new users will be auto-verified and credentials sign-in works immediately.
# Accepts: true|1|yes  /  false|0|no
EMAIL_VERIFICATION_ENABLED=
